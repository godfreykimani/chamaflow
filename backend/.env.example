# ── ChamaFlow Backend Environment ──────────────────────────────────────────────
# Copy this file to .env and fill in real values before running

# Server
PORT=3001
NODE_ENV=development          # change to "production" when deployed

# Security — REQUIRED in production (generate with: openssl rand -hex 64)
JWT_SECRET=chamaflow-dev-secret-change-in-production
JWT_EXPIRY=7d

# Database
DB_PATH=./chamaflow.db        # local SQLite path

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173

# AI Transcription — at least one required for meeting recording
GROQ_API_KEY=           # groq.com — Whisper Large v3 (fast, free tier)
HUGGINGFACE_API_KEY=    # huggingface.co — Whisper Large v3 Turbo (open-source, free tier)

# WhatsApp — Meta Cloud API (optional; leave blank to disable)
# Get these from developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
APP_URL=https://chamaflow-six.vercel.app
